{
	"appId": "com.vpsmanager.app",
	"appName": "VPS Manager",
	"webDir": "dist",
	"server": {
		"androidScheme": "https",
		"allowMixedContent": true,
		"cleartext": true
	},
	"android": {
		"allowMixedContent": true,
		"webContentsDebuggingEnabled": false
	},
	"plugins": {
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#0d1117",
			"overlaysWebView": false
		},
		"Keyboard": {
			"resize": "native",
			"resizeOnFullScreen": true
		}
	}
}
